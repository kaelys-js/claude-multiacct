{
	"$schema": "./.schemas/package.json",
	"name": "foundation-registry",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Business-as-Code governance registry: owned decision records (PRD/PDR/ADR/SPEC/tasks/release) governing how clients are built. Not a runtime application.",
	"license": "SEE LICENSE IN LICENSE",
	"author": {
		"name": "TTT Studios",
		"email": "no-reply@ttt.studios"
	},
	"homepage": "https://github.com/tttstudios/foundation-registry#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tttstudios/foundation-registry.git"
	},
	"bugs": {
		"url": "https://github.com/tttstudios/foundation-registry/issues"
	},
	"keywords": [
		"adr",
		"business-as-code",
		"decision-records",
		"governance",
		"prd",
		"registry",
		"spec"
	],
	"engines": {
		"node": "26.5.0",
		"pnpm": "11.12.0"
	},
	"packageManager": "pnpm@11.12.0",
	"scripts": {
		"ci:local": "node packages/shared/utils/qa/src/ci-local.ts",
		"ci:local:clean": "node packages/shared/utils/qa/src/ci-local.ts --clean",
		"clean": "([ -d packages ] && turbo run clean --filter='./packages/*' || true) && rm -rf coverage .turbo dist build",
		"clean:all": "([ -d packages ] && turbo run clean --filter='./packages/*' || true) && rm -rf coverage .turbo dist build node_modules .mise",
		"fix:deps": "syncpack fix --config packages/shared/config/syncpack.json",
		"format": "pnpm qa:format",
		"format:check:oxfmt": "node packages/shared/utils/qa/src/format.ts --only oxfmt --check",
		"format:check:syncpack": "node packages/shared/utils/qa/src/format.ts --only syncpack --check",
		"format:check:taplo": "node packages/shared/utils/qa/src/format.ts --only taplo --check",
		"format:oxfmt": "node packages/shared/utils/qa/src/format.ts --only oxfmt",
		"format:syncpack": "node packages/shared/utils/qa/src/format.ts --only syncpack",
		"format:taplo": "node packages/shared/utils/qa/src/format.ts --only taplo",
		"lint": "pnpm qa:lint",
		"lint:check-jsonschema": "node packages/shared/utils/qa/src/lint.ts --only check-jsonschema",
		"lint:commit": "commitlint --config packages/shared/config/commitlint.json --edit",
		"lint:editorconfig": "node packages/shared/utils/qa/src/lint.ts --only editorconfig",
		"lint:gitleaks": "node packages/shared/utils/qa/src/lint.ts --only gitleaks",
		"lint:gitmeta": "node packages/shared/utils/qa/src/lint.ts --only gitmeta",
		"lint:hygiene": "node packages/shared/utils/qa/src/lint.ts --only hygiene",
		"lint:markdownlint": "node packages/shared/utils/qa/src/lint.ts --only markdownlint",
		"lint:oxlint": "node packages/shared/utils/qa/src/lint.ts --only oxlint",
		"lint:reuse": "node packages/shared/utils/qa/src/lint.ts --only reuse",
		"lint:schema": "node packages/shared/utils/qa/src/lint.ts --only schema",
		"lint:syncpack": "node packages/shared/utils/qa/src/lint.ts --only syncpack",
		"lint:taplo": "node packages/shared/utils/qa/src/lint.ts --only taplo",
		"lint:typescript": "node packages/shared/utils/qa/src/lint.ts --only typescript",
		"lint:yamllint": "node packages/shared/utils/qa/src/lint.ts --only yamllint",
		"prepare": "lefthook install",
		"qa:format": "turbo run //#qa:format:all",
		"qa:format:all": "node -e \"process.exit(0)\"",
		"qa:format:check": "turbo run //#qa:format:check:all",
		"qa:format:check:all": "node -e \"process.exit(0)\"",
		"qa:hooks": "lefthook validate",
		"qa:lint": "turbo run //#qa:lint:all",
		"qa:lint:all": "node -e \"process.exit(0)\"",
		"qa:schema": "node packages/shared/utils/qa/src/schema-check.ts",
		"qa:test": "turbo run //#test",
		"qa:test:coverage": "turbo run //#test:coverage:run",
		"sync": "node packages/shared/utils/sync/src/versions.ts && node packages/shared/utils/sync/src/schemas.ts && node packages/shared/utils/sync/src/turbo.ts",
		"sync-upstream": "git fetch upstream && git merge --ff-only upstream/main && pnpm install",
		"sync-upstream:opt-in": "node packages/shared/utils/sync/src/opt-in-sync-upstream.ts",
		"sync:check": "node packages/shared/utils/sync/src/versions.ts --check && node packages/shared/utils/sync/src/turbo.ts --check && node packages/shared/utils/sync/src/schemas.ts --check",
		"sync:schemas": "node packages/shared/utils/sync/src/schemas.ts",
		"sync:turbo": "node packages/shared/utils/sync/src/turbo.ts",
		"sync:versions": "node packages/shared/utils/sync/src/versions.ts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:coverage:run": "vitest run --coverage"
	},
	"devDependencies": {
		"@commitlint/cli": "21.2.1",
		"@commitlint/config-conventional": "21.2.0",
		"@foundation/config": "workspace:*",
		"@types/node": "26.1.1",
		"@vitest/coverage-v8": "4.1.10",
		"lefthook": "2.1.10",
		"syncpack": "15.3.2",
		"turbo": "2.10.4",
		"typescript": "7.0.2",
		"vitest": "4.1.10"
	}
}
