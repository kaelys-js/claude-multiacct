{
	// Self-hosted Renovate config for foundation-registry. Scope: npm/pnpm
	// workspace deps + mise-pinned toolchain.
	//
	// 1. npm/pnpm deps. The built-in `npm` manager reads the workspace
	//    package.json files + pnpm-lock.yaml. patch/minor/digest are auto-merged
	//    after CI; major is a review PR. lockFileMaintenance refreshes the lock.
	//
	// 2. mise tools. The built-in `mise` manager reads mise.toml `[tools]`
	//    (node, pnpm, oxlint, gitleaks, etc.). Same policy as npm:
	//    patch/minor auto-merge after CI, major -> review PR.
	//
	// 3. GitHub Actions. The built-in `github-actions` manager reads every
	//    `uses:` line in .github/workflows/*.yml. Same policy as npm:
	//    patch/minor/digest auto-merge, major review PR. Every pin is a full
	//    commit SHA with a `# vX.Y.Z` comment; helpers:pinGitHubActionDigestsToSemver
	//    keeps the comment fresh whenever Renovate bumps the digest.
	//
	// All auto-merges wait a `minimumReleaseAge` cool-down so brand-new releases
	// aren't merged the instant they publish. Every Renovate commit is
	// `chore(deps): …`, which passes this repo's commitlint for ALL managers.
	$schema: "https://docs.renovatebot.com/renovate-schema.json",

	extends: [
		"config:recommended",
		":dependencyDashboard",
		":semanticCommits",
		"helpers:pinGitHubActionDigestsToSemver",
	],

	timezone: "America/Vancouver",

	// Conservative cadence: once a day, before 06:00 local. Weekly digest churn
	// stays low-noise and lands before the workday.
	schedule: ["* 0-5 * * *"],

	dependencyDashboard: true,

	// --- Commit / PR message shape -------------------------------------------
	// Must satisfy this repo's commitlint: type MUST be in the type-enum and
	// "chore" IS in it; scope is kebab-case. So every Renovate commit reads:
	//   chore(deps): update <dep> to <newvalue>
	// which passes type-enum, type-case, scope-case, subject-empty.
	semanticCommits: "enabled",
	semanticCommitType: "chore",
	semanticCommitScope: "deps",
	commitMessagePrefix: "chore(deps):",
	// Renovate's default body appends the changelog etc.; the header above is the
	// only line commitlint validates and it is compliant.

	// --- DCO signoff -----------------------------------------------------------
	// Renovate's commits are authored by the shared GitHub App bot
	// (kaelys-js-renovate[bot]); the same trailer is injected on every repo so
	// probot/dco (when installed anywhere in the org) sees a consistent signoff.
	commitBody: "Signed-off-by: kaelys-js-renovate[bot] <304942767+kaelys-js-renovate[bot]@users.noreply.github.com>",

	// --- Concurrency / noise control -----------------------------------------
	// Throttle to one open Renovate PR at a time / one new PR per hour so the
	// self-hosted runner (kaelys-mac-mini) is not swamped by parallel Renovate
	// churn and the CI-minutes-per-day floor stays predictable. Renovate
	// closes over-limit PRs on its next scheduled run.
	prConcurrentLimit: 1,
	prHourlyLimit: 1,
	// Rebase stale branches so the digest/tag stays fresh until merge.
	rebaseWhen: "behind-base-branch",

	// --- Auto-merge policy ---------------------------------------------------
	// platformAutomerge is DELIBERATELY false throughout this file. Native
	// GitHub platform auto-merge waits for ALL required merge requirements
	// (checks + reviews) BEFORE it triggers; ruleset `bypass_actors` only apply
	// at the actual merge API call, NOT at the auto-merge trigger check. On
	// this solo-dev User account the main-protection ruleset (see
	// kaelys-js-infra/terraform/rulesets.tf) requires 1 approving + code-owner
	// review which no other human can give, so platformAutomerge=true sits
	// BLOCKED (mergeStateStatus=BLOCKED, reviewDecision=REVIEW_REQUIRED)
	// forever — verified through 2026-07-19. With platformAutomerge=false,
	// Renovate polls the PR on its next dispatch after CI turns green and
	// calls the merge REST API directly with its App installation token;
	// `kaelys-js-renovate` (App id 4296679) has bypass_mode="always" in every
	// main-protection ruleset's bypass_actors, so the merge call succeeds
	// without a review. Trade-off: PRs merge on Renovate's next dispatch after
	// CI turns green, not the instant it turns green. Acceptable for deps.

	// Cool-down: never auto-merge a release younger than this. Guards against
	// a compromised/yanked just-published version landing hands-off. (The pnpm
	// workspace's own minimumReleaseAge is 0; this is Renovate's independent gate.)
	minimumReleaseAge: "7 days",

	// --- Security / vulnerability updates ------------------------------------
	// Dependabot security-update PRs are OFF fleet-wide (kaelys-js-infra
	// terraform/security.tf: dependabot_security_updates = false). The exact
	// engines.node pin makes Dependabot's updater fail with
	// ERR_PNPM_UNSUPPORTED_ENGINE on every lockfile write, so it re-fails each
	// advisory instead of shipping a fix. Renovate owns CVE remediation now:
	// GitHub's vulnerability-alert stream stays on (the managed_repo
	// vulnerability_alerts = true) and this block turns those alerts into
	// Renovate security PRs. No automerge / platformAutomerge keys here on
	// purpose — a security bump lands as a `security`-labelled review PR, and
	// the fleet renovate-config audit (kaelys-js-infra
	// scripts/audit-renovate-config.sh) stays balanced.
	vulnerabilityAlerts: {
		enabled: true,
		labels: ["security"],
	},

	// Enabled managers:
	//   - npm             -> package.json (× workspace) + pnpm-lock.yaml
	//   - mise            -> mise.toml [tools] versions (all tools EXCEPT node + pnpm,
	//                       which are handled by custom.regex below for bump-together)
	//   - custom.regex    -> mise.toml `node = "..."` + `pnpm = "..."` lines, matched
	//                       with depName == the npm engines depName so Renovate groups
	//                       mise.toml + package.json engines into ONE PR
	//   - github-actions  -> .github/workflows/*.yml `uses:` lines (SHA-pinned)
	// Everything else stays off.
	enabledManagers: ["npm", "mise", "custom.regex", "github-actions"],

	// --- customManager: mise.toml node + pnpm (bump-together) ----------------
	// The built-in `mise` manager reads mise.toml [tools], but its datasources for
	// node + pnpm differ from what npm's engines manager emits — so without help,
	// a node bump and its matching engines.node bump land in TWO separate PRs.
	//
	// These customManagers match ONLY the `node = "..."` and `pnpm = "..."` lines
	// in mise.toml and re-declare them with the same depName the npm manager uses
	// for package.json engines. Combined with the `node + pnpm toolchain` group
	// rule below, Renovate groups mise.toml + package.json engines into a single
	// PR per version. Built-in mise handling of node + pnpm is disabled via a
	// packageRule below so there is no double-management.
	customManagers: [
		{
			customType: "regex",
			managerFilePatterns: ["/^mise\\.toml$/"],
			matchStrings: ['^node\\s*=\\s*"(?<currentValue>[^"]+)"'],
			depNameTemplate: "node",
			packageNameTemplate: "nodejs/node",
			datasourceTemplate: "github-releases",
			versioningTemplate: "node",
			extractVersionTemplate: "^v(?<version>.+)$",
		},
		{
			customType: "regex",
			managerFilePatterns: ["/^mise\\.toml$/"],
			matchStrings: ['^pnpm\\s*=\\s*"(?<currentValue>[^"]+)"'],
			depNameTemplate: "pnpm",
			packageNameTemplate: "pnpm",
			datasourceTemplate: "npm",
			versioningTemplate: "npm",
		},
	],

	// Keep pnpm-lock.yaml fresh (dedupe / transitive security bumps) via a
	// scheduled lockfile-only PR. Auto-merged after CI (see packageRules).
	lockFileMaintenance: {
		enabled: true,
		automerge: true,
		platformAutomerge: false,
	},

	// --- packageRules --------------------------------------------------------
	// Automerge matrix (all automerges gated on green CI + minimumReleaseAge):
	//   npm     patch/minor/digest      -> automerge (devDeps grouped)
	//   npm     major                   -> review PR (never grouped)
	//   mise    patch/minor             -> automerge (grouped)
	//   mise    major                   -> review PR (never grouped)
	//   lockFileMaintenance             -> automerge (configured above)
	packageRules: [
		// ── jdx/mise-action v4.2.1 pin (see kaelys-js#15, kaelys-js-infra#56) ──
		// v4.2.1 (jdx/mise-action#556 "fix: exclude PATH from environment
		// export") stops propagating mise-managed shim PATH entries into the
		// action's exported env, so subsequent steps that call `pnpm` via mise
		// shims fail with `pnpm is not a valid shim`. Pin to v4.2.0 until
		// upstream ships a fix.
		{
			matchDepNames: ["jdx/mise-action"],
			allowedVersions: "<4.2.1",
		},

		// ── pnpm 11.13.1 pin (see ttt-studio#42) ────────────────────────────
		// pnpm 11.13.1 is a broken release: `pnpm install --frozen-lockfile`
		// against a lockfile written by 11.13.0 crashes with
		// `Cannot use 'in' operator to search for 'integrity' in undefined`
		// (pnpm/pnpm#12959, incompletely addressed by #12961; upstream added
		// release gating in #13082 to prevent similar breakage). Pin to
		// <11.13.1 until pnpm ships a fixed 11.13.2.
		{
			matchDepNames: ["pnpm"],
			allowedVersions: "<11.13.1",
		},

		// ── node + pnpm bump-together (mise.toml + package.json engines) ────
		{
			// Prevent double-management: the built-in mise manager also reads
			// mise.toml [tools], so disable its handling of node + pnpm SPECIFICALLY.
			// Every OTHER mise tool (typescript, oxlint, ruff, etc.) still runs
			// under the mise manager unchanged.
			matchManagers: ["mise"],
			matchDepNames: ["node", "pnpm"],
			enabled: false,
		},
		{
			// Group mise.toml (custom.regex) + package.json engines (npm) into
			// ONE PR per bump — same depName + same target version = one branch.
			// patch/minor auto-merges (CI validates both files together).
			matchDepNames: ["node", "pnpm"],
			matchManagers: ["custom.regex", "npm"],
			groupName: "node + pnpm toolchain",
			commitMessageTopic: "node + pnpm toolchain",
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
		},
		{
			// Major bumps of node/pnpm (a new Node major etc.) are a human
			// decision; review PR.
			matchDepNames: ["node", "pnpm"],
			matchManagers: ["custom.regex", "npm"],
			matchUpdateTypes: ["major"],
			groupName: "node + pnpm toolchain",
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			minimumReleaseAge: "21 days",
		},

		// ── npm / pnpm workspace deps ────────────────────────────────────────
		{
			// patch/minor/digest are non-breaking by semver; CI (format/lint/types/
			// tests) fully validates JS deps, so auto-merge after green CI. devDeps
			// (all our deps are devDependencies) grouped to keep PR noise down.
			matchManagers: ["npm"],
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			groupName: "npm dev dependencies (non-major)",
			commitMessageTopic: "npm dev dependencies",
		},
		{
			// Major npm bumps can break; review PR, its own PR (never grouped).
			matchManagers: ["npm"],
			matchUpdateTypes: ["major"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			minimumReleaseAge: "21 days",
		},

		// ── mise toolchain ───────────────────────────────────────────────────
		{
			// patch/minor toolchain bumps (linters/formatters/runtimes) auto-merge
			// after green CI — CI runs every tool via `mise exec`, so a broken tool
			// version fails CI before merge. Grouped to keep noise down.
			matchManagers: ["mise"],
			matchUpdateTypes: ["patch", "minor"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			groupName: "mise toolchain (non-major)",
			commitMessageTopic: "mise toolchain",
		},
		{
			// Major toolchain bumps (e.g. a new Node major) are a human decision;
			// review PR, its own PR (never grouped).
			matchManagers: ["mise"],
			matchUpdateTypes: ["major"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			minimumReleaseAge: "21 days",
		},

		// ── GitHub Actions ───────────────────────────────────────────────────
		{
			// patch/minor/digest bumps for the workflow `uses:` pins auto-merge
			// after green CI. Grouped so a single actions/checkout or mise-action
			// bump lands as one PR across every workflow.
			matchManagers: ["github-actions"],
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			groupName: "github actions (non-major)",
			commitMessageTopic: "github actions",
		},
		{
			// Major action bumps (e.g. actions/checkout v4 -> v5) can change
			// input names; review PR, its own PR (never grouped).
			matchManagers: ["github-actions"],
			matchUpdateTypes: ["major"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: false,
			minimumReleaseAge: "21 days",
		},
	],
}
