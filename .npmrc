# pnpm 11 reads non-registry settings from pnpm-workspace.yaml, NOT here
# (.npmrc is auth/registry-only for pnpm). The keys below are a mirror for any
# npm-compatible tooling; pnpm honours the effective copies in
# pnpm-workspace.yaml (saveExact / savePrefix / engineStrict).
save-exact = true
save-prefix = ""
engine-strict = true
