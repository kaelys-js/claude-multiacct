# https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# ============================================
# Package Initialization
# ============================================
init-author-name = "TTT Studios"
init-author-email = "noreply@ttt.example"
init-author-url = "https://ttt.example"
init-license = "UNLICENSED"
init-version = "0.0.0"

# ============================================
# Publishing
# ============================================
publish-branch = "main"
access = public
git-tag-version = true
commit-hooks = true
tag-version-prefix = "v"

# ============================================
# Version Resolution
# ============================================
save-prefix = ""
save-exact = true

# ============================================
# Engine Enforcement
# ============================================
engine-strict = true

# ============================================
# Performance & Caching
# ============================================
prefer-offline = true
fetch-retries = 3
fetch-retry-mintimeout = 10000
fetch-retry-maxtimeout = 60000

# ============================================
# Security
# ============================================
audit = true
audit-level = moderate

# ============================================
# pnpm: Peer Dependencies
# ============================================
auto-install-peers = true
strict-peer-dependencies = false

# ============================================
# pnpm: Workspace
# ============================================
link-workspace-packages = true
save-workspace-protocol = rolling
dedupe-direct-deps = true
verify-deps-before-run = install

# ============================================
# pnpm: Node.js Version
# ============================================
use-node-version = 26.4.0

# ============================================
# pnpm: Network
# ============================================
network-concurrency = 16

# ============================================
# pnpm: Hoisting
# ============================================
shamefully-hoist = false
public-hoist-pattern[] = *types*
public-hoist-pattern[] = *vitest*
public-hoist-pattern[] = *oxlint*
public-hoist-pattern[] = *oxfmt*

# ============================================
# pnpm: Install Behaviour
# ============================================
prefer-frozen-lockfile = true
loglevel = warn
node-linker = isolated
package-import-method = hardlink
dedupe-peer-dependents = true
side-effects-cache = true
package-manager-strict = true
confirm-modules-purge = false
manage-package-manager-versions = true

# ============================================
# Registry
# ============================================
strict-ssl = true
registry = https://registry.npmjs.org
verify-store-integrity = true
