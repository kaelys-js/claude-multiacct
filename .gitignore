# Git: Negations (keep these tracked)
!.env.example
!.env.template
!.env.schema
!.dev.vars.example
!.changeset/README.md
!.changeset/config.json

# Git: Yarn PnP exceptions
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Git: Private keys (too broad for shared partial)
*.key

# Git: VS Code (keep config files)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Claude Code (AI dev tool — workspace config)
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/scripts/
!.claude/skills/

# Git worktrees (Claude Code isolation)
.worktrees/

# mise tool installations (workspace-scoped, auto-generated)
.mise/
# Keep the bootstrap script committed (./bin/mise is the entry point)
!bin/mise

# Serena (MCP): commit project.yml + memories; ignore local caches/logs.
.serena/cache/
.serena/*.log
.serena/logs/

# cocoindex (MCP): local semantic index — regenerated by `ccc init && ccc index`.
.cocoindex_code/

# Governance records are never build output — the `build/` rule above would
# otherwise clobber the records/build/ domain directory (now inside the
# @foundation/registry package). Keep the records tree.
!packages/products/registry/records/build/

# Lock files — DO NOT IGNORE
# pnpm-lock.yaml MUST be committed
!pnpm-lock.yaml

# local `act` wrapper artifacts (secrets file, log tmp)
.act/

# Claude Code worktrees — ephemeral, per-session
.claude/worktrees/

