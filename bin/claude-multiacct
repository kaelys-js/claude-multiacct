#!/usr/bin/env bash
# claude-multiacct — CLI for managing any number of Claude Desktop instances
# under different accounts on the same Mac. Dispatcher over lib/*.sh.
#
# Subcommands:
#   install                           symlink this CLI into ~/.local/bin
#   uninstall                         remove the ~/.local/bin symlink
#   init                              detect primary + write example instances.yaml
#   add-instance <label> --email <e>  install a new mirror instance
#   remove-instance <label> [--keep-userdata]
#   list [--tsv]                      show all instances + health (--tsv for machine)
#   repair [<label>]                  re-run install steps for one or all instances
#   refresh-clones                    rebuild every mirror clone from the current
#                                     /Applications/Claude.app (fires automatically
#                                     via WatchPaths on Squirrel update)
#   primary-patch                     patch /Applications/Claude.app in place —
#                                     inject the propagation + rc-enforcer IIFEs +
#                                     write the managed-config plist route, then
#                                     ad-hoc re-sign. Squirrel-cycle safe: the
#                                     primary-patch-refresh launchd agent re-applies
#                                     after every Squirrel update. Rule 12
#                                     disclosure: invalidates Apple's original
#                                     signature until the next Squirrel drop or
#                                     manual reinstall.
#   primary-unpatch                   restore /Applications/Claude.app's app.asar
#                                     from the multiacct-owned backup + remove the
#                                     mirror-prefs plist. Ad-hoc signature stays;
#                                     Apple signature returns on next Squirrel drop.
#   sync-now                          manually trigger primary → mirrors sync
#   sync-log [--tail]                 print the sessions-sync log (--tail follows it)
#   exec <label> [--] <cmd> [args…]   run <cmd> with CLAUDE_CONFIG_DIR +
#                                     CHROMIUM_USER_DATA_DIR pointing at <label>'s
#                                     data; with NO cmd, prints the env-var
#                                     assignments the wrapper would export (dry-run)
#   doctor [--json]                   deep diagnostic report; --json emits a
#                                     machine-parseable report suitable for
#                                     diffing between two Macs (see
#                                     docs/cross-mac-setup.md)
#   qa {lint|test}                    dev helpers (shellcheck + bats)

set -euo pipefail

# Resolve symlinks so `install` links in ~/.local/bin still find ../lib.
# Pure-bash loop (no realpath dependency); handles chained symlinks + relative
# link targets. Terminates once BASH_SOURCE hits a real file.
_cma_self="${BASH_SOURCE[0]}"
while [[ -L "$_cma_self" ]]; do
	_cma_link="$(readlink "$_cma_self")"
	[[ "$_cma_link" != /* ]] && _cma_link="$(cd "$(dirname "$_cma_self")" && pwd)/$_cma_link"
	_cma_self="$_cma_link"
done
CMA_LIB="$(cd "$(dirname "$_cma_self")/../lib" && pwd)"
CMA_BIN="$(cd "$(dirname "$_cma_self")" && pwd)"
unset _cma_self _cma_link
# shellcheck source=../lib/common.sh
. "$CMA_LIB/common.sh"

usage() {
	cat <<USAGE
claude-multiacct — manage multiple Claude Desktop instances on one Mac

usage:
  claude-multiacct install
  claude-multiacct uninstall
  claude-multiacct init
  claude-multiacct add-instance <label> --email <email>
  claude-multiacct remove-instance <label> [--keep-userdata] [--keep-configdir]
  claude-multiacct list [--tsv]
  claude-multiacct repair [<label>]
  claude-multiacct refresh-clones
  claude-multiacct primary-patch
  claude-multiacct primary-unpatch
  claude-multiacct sync-now
  claude-multiacct sync-log [--tail]
  claude-multiacct exec <label> [--] <cmd> [args…]
  claude-multiacct doctor [--json]
  claude-multiacct qa {lint|test}

labels: lowercase [a-z0-9-]+, no leading/trailing hyphen. 'primary' is reserved.
config: $CMA_CONFIG_FILE
docs:   see README.md and docs/ under $CMA_REPO_ROOT
USAGE
}

# The install subcommand places a symlink into ~/.local/bin so the CLI works
# from any shell without needing the repo dir on PATH. Chezmoi-safe: ~/.local/bin
# is not an `exact_` chezmoi dir on any of our machines, and mac-mini-config
# autosync uses `re-add` (managed files only), so the symlink won't be swept.
CMA_INSTALL_TARGET="$HOME/.local/bin/claude-multiacct"

cmd_install() {
	local self="$CMA_BIN/claude-multiacct"
	mkdir -p "$(dirname "$CMA_INSTALL_TARGET")"

	if [[ -L "$CMA_INSTALL_TARGET" ]]; then
		local existing
		existing="$(readlink "$CMA_INSTALL_TARGET")"
		if [[ "$existing" == "$self" ]]; then
			cma_ok "already installed at $CMA_INSTALL_TARGET"
			return 0
		fi
		cma_die "install: $CMA_INSTALL_TARGET is a symlink to $existing (not this repo). Remove it manually or run \`uninstall\` there."
	fi
	if [[ -e "$CMA_INSTALL_TARGET" ]]; then
		cma_die "install: $CMA_INSTALL_TARGET exists and is NOT a symlink. Remove it manually if you're sure it's not something you want."
	fi

	ln -s "$self" "$CMA_INSTALL_TARGET"
	cma_ok "linked $CMA_INSTALL_TARGET → $self"
	cma_dim "  ensure ~/.local/bin is on your PATH"

	# Chunk Y — patch the primary /Applications/Claude.app so the propagation
	# and rc-enforcer IIFEs are active on every session under the primary
	# account too. `cmd_primary_patch` is idempotent (no-op when the markers
	# are already present), so this is safe to fire on every `install` run.
	#
	# Skipped when the primary bundle is missing (fresh machine without Claude
	# Desktop installed) or when the primary is currently running (would race
	# codesign). Both branches are surfaced to the operator.
	if [[ ! -d "$CMA_SOURCE_CLAUDE_APP" ]]; then
		cma_warn "install: primary Claude.app missing at $CMA_SOURCE_CLAUDE_APP — skipping primary-patch (install Claude Desktop, then run \`claude-multiacct primary-patch\`)"
		return 0
	fi
	if pgrep -f '/Applications/Claude\.app/Contents/MacOS/Claude' >/dev/null 2>&1; then
		cma_warn "install: primary Claude Desktop is running; quit it and run \`claude-multiacct primary-patch\` to activate the rc-enforcer on the primary"
		return 0
	fi
	cmd_primary_patch
}

cmd_uninstall() {
	local self="$CMA_BIN/claude-multiacct"

	if [[ ! -e "$CMA_INSTALL_TARGET" ]] && [[ ! -L "$CMA_INSTALL_TARGET" ]]; then
		cma_ok "not installed — nothing to remove"
		return 0
	fi
	if [[ ! -L "$CMA_INSTALL_TARGET" ]]; then
		cma_die "uninstall: $CMA_INSTALL_TARGET is not a symlink — refusing to touch it"
	fi
	local existing
	existing="$(readlink "$CMA_INSTALL_TARGET")"
	if [[ "$existing" != "$self" ]]; then
		cma_die "uninstall: $CMA_INSTALL_TARGET points at $existing, not this repo — refusing to remove"
	fi

	# Chunk Y — restore /Applications/Claude.app to pristine BEFORE removing
	# the CLI symlink. Otherwise a user who runs `uninstall` and then
	# manually removes the repo checkout would be left with a patched primary
	# and no easy path to restore it. If unpatch fails (no backup, primary
	# running, etc.), surface the failure and refuse to proceed — the CLI
	# symlink stays so the operator can retry after fixing the blocker.
	if [[ -d "$CMA_SOURCE_CLAUDE_APP" ]] &&
		[[ -f "$CMA_SOURCE_CLAUDE_APP/Contents/Resources/app.asar.multiacct-backup" ]]; then
		if pgrep -f '/Applications/Claude\.app/Contents/MacOS/Claude' >/dev/null 2>&1; then
			cma_die "uninstall: primary Claude Desktop is running; quit it and retry"
		fi
		cmd_primary_unpatch
	fi

	rm -f "$CMA_INSTALL_TARGET"
	cma_ok "removed $CMA_INSTALL_TARGET"
}

cmd_init() {
	mkdir -p "$CMA_CONFIG_DIR"
	if [[ -f "$CMA_CONFIG_FILE" ]]; then
		cma_warn "config already exists at $CMA_CONFIG_FILE — not overwriting"
		cma_dim "  to reset: back it up and re-run \`init\`"
		return 0
	fi

	# Detect the primary's email. The paths themselves are hard-coded in the
	# example config template (~/.claude, ~/Library/Application Support/Claude);
	# `sed` substitutes the tilde-forms so the config file is portable across users.
	local p_email
	p_email="$(cma_primary_email "$CMA_PRIMARY_USERDATA")"

	# Copy the example config and substitute the detected primary.
	local example="$CMA_REPO_ROOT/config/instances.example.yaml"
	[[ -f "$example" ]] || cma_die "example config missing at $example"

	# `sed` with `|` delimiter avoids escaping the path slashes.
	sed \
		-e "s|__PRIMARY_EMAIL__|${p_email:-you@example.com}|g" \
		-e "s|__PRIMARY_CONFIGDIR__|~/.claude|g" \
		-e "s|__PRIMARY_USERDATA__|~/Library/Application Support/Claude|g" \
		"$example" >"$CMA_CONFIG_FILE"
	chmod 600 "$CMA_CONFIG_FILE"
	cma_ok "wrote $CMA_CONFIG_FILE"
	cma_dim "  primary detected: email=${p_email:-unknown}"
	cma_dim "  next: edit the file to add mirror instances, then run \`add-instance <label>\` OR add via CLI:"
	cma_dim "    claude-multiacct add-instance b --email you@example.com"

	# Install the launchd sync agent (idempotent).
	"$CMA_LIB/install-launchd.sh"
}

cmd_add_instance() {
	local label="" email=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--email)
			email="$2"
			shift 2
			;;
		--*) cma_die "add-instance: unknown flag: $1" ;;
		*)
			label="$1"
			shift
			;;
		esac
	done
	[[ -n "$label" ]] || cma_die "add-instance: label required"
	[[ -n "$email" ]] || cma_die "add-instance: --email required"
	cma_validate_label "$label"

	cma_require yq
	cma_require_config

	# If already present in instances.yaml, refuse (call repair instead).
	if yq -r '.instances[].label' "$CMA_CONFIG_FILE" | grep -qxF "$label"; then
		cma_die "instance '$label' already in $CMA_CONFIG_FILE — use \`repair $label\` to reinstall in place"
	fi

	# Append the instance to instances.yaml (yq eval-in-place).
	local snap
	snap="$(cma_backup_snapshot "$CMA_CONFIG_FILE" "config")"
	cma_dim "  snapshot: $snap"
	yq eval ".instances += [{\"label\": \"$label\", \"email\": \"$email\"}]" -i "$CMA_CONFIG_FILE"
	cma_ok "added instance '$label' to $CMA_CONFIG_FILE"

	# Run the installer for the new instance.
	"$CMA_LIB/install-instance.sh" "$label"

	# Re-render the launchd plist (idempotent; picks up new mirror path).
	"$CMA_LIB/install-launchd.sh"
}

cmd_remove_instance() {
	local label="" flags=()
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--keep-userdata | --keep-configdir)
			flags+=("$1")
			shift
			;;
		--*) cma_die "remove-instance: unknown flag: $1" ;;
		*)
			label="$1"
			shift
			;;
		esac
	done
	[[ -n "$label" ]] || cma_die "remove-instance: label required"
	cma_validate_label "$label"

	cma_require yq
	cma_require_config

	# Tear down on-disk artifacts first (uses instances.yaml, so remove config LAST).
	# ${flags[@]+"${flags[@]}"} expands to nothing when the array is empty — safe under set -u.
	"$CMA_LIB/uninstall-instance.sh" "$label" ${flags[@]+"${flags[@]}"}

	# Remove the instance from instances.yaml.
	local snap
	snap="$(cma_backup_snapshot "$CMA_CONFIG_FILE" "config")"
	cma_dim "  snapshot: $snap"
	yq eval "del(.instances[] | select(.label == \"$label\"))" -i "$CMA_CONFIG_FILE"
	cma_ok "removed instance '$label' from $CMA_CONFIG_FILE"
}

cmd_list() {
	cma_require_config
	# Forward any flags (currently --tsv) through to discover.sh. The forwarded
	# arg is validated inside discover.sh; unknown flags there fall out of the
	# `--tsv`-only case and get treated as a label (which discover ignores).
	"$CMA_LIB/discover.sh" "$@"
}

cmd_repair() {
	cma_require_config
	local label="${1:-}"
	if [[ -n "$label" ]]; then
		cma_validate_label "$label"
		"$CMA_LIB/install-instance.sh" "$label"
	else
		# Repair all instances.
		local l
		while IFS= read -r l; do
			[[ -z "$l" ]] && continue
			"$CMA_LIB/install-instance.sh" "$l"
		done < <(cma_list_labels)
	fi
	# Enforce the User-tier remoteControlAtStartup on the PRIMARY's settings.json
	# too. install-instance.sh handles the mirrors; the primary configDir is not
	# an instance in instances.yaml, so a separate touchpoint is required. Merge
	# semantics preserve every existing user key.
	local p_cdir
	p_cdir="$(cma_primary_configdir)"
	if [[ -d "$p_cdir" ]]; then
		cma_ensure_setting_bool "$p_cdir/settings.json" remoteControlAtStartup true
	fi

	# Chunk Y — re-patch the primary /Applications/Claude.app if the
	# multiacct-owned markers have drifted (Squirrel drop replaced our patch
	# with a fresh pristine, or the asar hash rotated for another reason).
	# `cmd_primary_patch` is idempotent — a rerun over an already-patched
	# primary is a no-op. Skip when the primary is missing or running (both
	# are cma_dim'd rather than fatal so repair still succeeds).
	if [[ ! -d "$CMA_SOURCE_CLAUDE_APP" ]]; then
		cma_dim "  = repair: primary Claude.app missing at $CMA_SOURCE_CLAUDE_APP — skipping primary-patch"
	elif pgrep -f '/Applications/Claude\.app/Contents/MacOS/Claude' >/dev/null 2>&1; then
		cma_dim "  = repair: primary Claude Desktop is running — skipping primary-patch (quit and re-run to include)"
	else
		cmd_primary_patch
	fi

	# Always re-render the launchd plist.
	"$CMA_LIB/install-launchd.sh"
}

cmd_sync_now() {
	cma_require_config
	cma_say "running sync manually (primary → mirrors)"
	"$CMA_BIN/claude-sessions-sync.sh"
	cma_ok "sync complete — see $CMA_LOG_DIR/sessions-sync.log"
}

# refresh-clones — rebuild every mirror's clone from the current
# /Applications/Claude.app. Called both interactively AND by the launchd
# WatchPaths agent on Info.plist mutation (which is what Squirrel writes on
# a Claude Desktop update). Log lives at CMA_LOG_DIR/clone-refresh.log so
# users can inspect what happened after an update.
#
# We refuse to run if any MIRROR clone is currently running — a live process
# holds file locks on Contents/Frameworks, so `ditto` over top will produce
# a corrupted clone and codesign will then reject it. We DELIBERATELY don't
# check for the primary Claude Desktop: Squirrel restarts the primary as
# part of applying an update, and blocking on the primary would defeat the
# entire point of the WatchPaths trigger.
cmd_refresh_clones() {
	cma_require_config

	local log="$CMA_LOG_DIR/clone-refresh.log"
	mkdir -p "$(dirname "$log")"

	# `pgrep -f` regex matches any process whose command line contains
	# "Claude Account <anything>.app/Contents/MacOS" — that's the exec path of
	# a running mirror clone (either the wrapper script or the Claude.real
	# process image). Matches the wrapper, main binary, and every helper.
	if pgrep -f 'Claude Account .*\.app/Contents/MacOS' >/dev/null 2>&1; then
		local msg="refresh-clones: at least one mirror clone is running; quit all Claude Account *.app processes and retry"
		printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$msg" >>"$log"
		cma_die "$msg"
	fi

	local ts
	ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	printf '%s === refresh-clones begin ===\n' "$ts" >>"$log"

	local label rc=0
	while IFS= read -r label; do
		[[ -z "$label" ]] && continue
		local row
		row="$(cma_resolve_instance "$label")"
		local _l _e cdir udata _cli app bid
		IFS=$'\t' read -r _l _e cdir udata _cli app bid <<<"$row"
		printf '%s   rebuilding clone label=%s → %s (bundleId=%s)\n' \
			"$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$label" "$app" "$bid" >>"$log"
		# shellcheck disable=SC2310  # keep going through other mirrors on one failure
		if ! "$CMA_LIB/build-clone-app.sh" "$label" "$bid" "$cdir" "$udata" "$app" >>"$log" 2>&1; then
			printf '%s   ✗ build-clone-app.sh failed for label=%s\n' \
				"$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$label" >>"$log"
			rc=1
		else
			printf '%s   ✓ clone rebuilt for label=%s\n' \
				"$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$label" >>"$log"
		fi
	done < <(cma_list_labels)

	printf '%s === refresh-clones end (rc=%d) ===\n' \
		"$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$rc" >>"$log"

	if [[ $rc -eq 0 ]]; then
		cma_ok "refresh-clones complete — see $log"
	else
		cma_warn "refresh-clones finished with errors — see $log"
	fi
	return "$rc"
}

# cmd_primary_patch — patch /Applications/Claude.app in place. This is the
# central touchpoint for Chunk Y: the propagation + rc-enforcer IIFEs +
# managed-config plist route + primary-mode plist all get applied to the
# primary bundle. Idempotent — a rerun over an already-patched bundle is a
# no-op (asar-patch-clone.sh detects each marker + skips its rewrite).
#
# Rule 12 disclosures (surfaced to stderr, visible on both interactive
# invocation AND launchd log output):
#   - Ad-hoc re-signature invalidates Anthropic's Developer ID signature on
#     the primary bundle. Squirrel's next drop-replace (a full-bundle update)
#     restores it; between now and then, `codesign -dv /Applications/Claude.app`
#     will show "adhoc" instead of Anthropic's Developer ID.
#   - Squirrel updates rewrite the primary bundle. The primary-patch-refresh
#     launchd agent re-runs this command on every Info.plist mtime change
#     so a fresh Squirrel drop is re-patched within seconds.
#
# Refuses to run while the primary Claude Desktop process is up — codesign
# would race with a live bundle's mmap'd Contents/Frameworks and produce a
# partially-signed bundle. The check matches BOTH the primary binary AND the
# clone-refresh Squirrel-writeback pattern, so refuseal is fail-loud.
cmd_primary_patch() {
	local src="$CMA_SOURCE_CLAUDE_APP"
	[[ -d "$src" ]] || cma_die "primary-patch: primary Claude.app missing at $src (override with CMA_SOURCE_CLAUDE_APP)"

	# Guard: primary running → refuse. `pgrep -f` regex matches the primary's
	# MacOS/Claude executable path. This matches the primary but explicitly
	# does NOT match a Claude Account mirror (which spawns from
	# ~/Applications/Claude Account …/Contents/MacOS/Claude — a distinct path).
	if pgrep -f '/Applications/Claude\.app/Contents/MacOS/Claude' >/dev/null 2>&1; then
		cma_die "primary-patch: primary Claude Desktop is running; quit it and retry (Cmd+Q, or \`pkill -TERM -f '/Applications/Claude.app/Contents/MacOS/Claude'\`)"
	fi

	cma_say "primary-patch: patching $src (asar + propagation IIFE + rc-enforcer IIFE + managed-config plist)"
	cma_warn "primary-patch: this invalidates Apple's original code signature on $src until the next Squirrel drop-replace"
	"$CMA_LIB/asar-patch-clone.sh" --mode=primary primary "$src"

	# The plist route also needs the User-tier remoteControlAtStartup=true on
	# the primary's configDir. cmd_repair does this for post-install runs;
	# duplicating it here means an operator who runs `primary-patch` in
	# isolation still gets the belt-and-braces wiring.
	local p_cdir
	p_cdir="$(cma_primary_configdir)"
	if [[ -d "$p_cdir" ]]; then
		cma_ensure_setting_bool "$p_cdir/settings.json" remoteControlAtStartup true
	fi

	cma_ok "primary patched; launch primary Claude Desktop to see the enforcer arm at [claude-multiacct-rc-enforcer]"
}

cmd_primary_unpatch() {
	local src="$CMA_SOURCE_CLAUDE_APP"
	[[ -d "$src" ]] || cma_die "primary-unpatch: primary Claude.app missing at $src"

	# Same running-guard as primary-patch — codesign vs. live mmap race.
	if pgrep -f '/Applications/Claude\.app/Contents/MacOS/Claude' >/dev/null 2>&1; then
		cma_die "primary-unpatch: primary Claude Desktop is running; quit it and retry"
	fi

	cma_say "primary-unpatch: restoring $src from multiacct backup"
	"$CMA_LIB/asar-patch-clone.sh" --mode=primary --unpatch primary "$src"
	cma_ok "primary unpatched; propagation + rc-enforcer no longer active on primary until next \`primary-patch\`"
}

# sync-log — QoL wrapper over `cat` / `tail -f` on the sync worker's log file.
# The log is where every sync (launchd-triggered or manual) records its
# progress; users with drifted mirrors reach for it first.
cmd_sync_log() {
	local follow=0
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--tail)
			follow=1
			shift
			;;
		--*) cma_die "sync-log: unknown flag: $1" ;;
		*) cma_die "sync-log: unexpected argument: $1" ;;
		esac
	done
	local log="$CMA_LOG_DIR/sessions-sync.log"
	[[ -f "$log" ]] || cma_die "sync-log: log not found at $log — has the sync worker run yet?"
	if [[ $follow -eq 1 ]]; then
		exec tail -f "$log"
	else
		cat "$log"
	fi
}

# exec — run a command with a mirror instance's env vars pre-set. Mirrors the
# env/sudo convention: `claude-multiacct exec <label> [--] <cmd> [args…]`.
# The optional `--` separator lets you pass a command whose first arg looks
# like a flag (`claude-multiacct exec b -- ls -la`).
#
# Env vars exported to the child process:
#   CLAUDE_CONFIG_DIR       — mirror's configDir (~/.claude-<label> by default)
#   CHROMIUM_USER_DATA_DIR  — mirror's userData (~/Library/Application Support/
#                             Claude-<Title> by default), for any nested
#                             Electron/Chromium tool that respects it
#
# stdin/stdout/stderr pass through and the child's exit code becomes ours.
#
# With NO command after <label> (and no `--`), prints the env-var assignments
# that WOULD be exported and exits 0. Useful for `eval "$(claude-multiacct exec b)"`
# or just inspecting the paths a mirror uses.
#
# When <cmd> is one of `claude` / `claude-code` / `code`, emits a warning on
# stderr about also passing `--user-data-dir=<userData>` if the tool supports
# it — the env vars alone don't reach every Chromium subprocess in every wrapper.
cmd_exec() {
	local label=""
	# First positional arg is the label. Anything after (with or without `--`)
	# is the command to run.
	if [[ $# -eq 0 ]]; then
		cma_die "exec: label required (usage: claude-multiacct exec <label> [--] <cmd> [args…])"
	fi
	label="$1"
	shift

	# Optional `--` separator. If present, drop it.
	if [[ "${1:-}" == "--" ]]; then
		shift
	fi

	cma_validate_label "$label"
	cma_require_config

	# Resolve the instance — dies loud if the label isn't in instances.yaml.
	local row
	row="$(cma_resolve_instance "$label")"
	local _l _e cdir udata _cli _app _bid
	IFS=$'\t' read -r _l _e cdir udata _cli _app _bid <<<"$row"

	# No command → dry-run: print the env-var assignments and exit.
	# Emitted in a form that `eval` can consume (shell-quoted values).
	if [[ $# -eq 0 ]]; then
		printf 'export CLAUDE_CONFIG_DIR=%q\n' "$cdir"
		printf 'export CHROMIUM_USER_DATA_DIR=%q\n' "$udata"
		return 0
	fi

	# Warn (non-fatal) when the child is a Claude CLI / VSCode-family tool. The
	# env vars we export are respected by most CLIs, but some Electron wrappers
	# only honor an explicit `--user-data-dir=` flag on the command line.
	case "$1" in
	claude | claude-code | code)
		cma_warn "exec: exporting CHROMIUM_USER_DATA_DIR=$udata for '$1'; also pass --user-data-dir=$udata if the tool supports it"
		;;
	esac

	# `exec` replaces this shell with the child so the child's exit code IS ours
	# and stdin/stdout/stderr pass through unchanged. `env` sets the two vars for
	# the child only, so callers of this function get an unmodified environment
	# back (relevant for tests that inspect the caller's env post-invocation,
	# though `exec` won't return here on success anyway).
	exec env "CLAUDE_CONFIG_DIR=$cdir" "CHROMIUM_USER_DATA_DIR=$udata" "$@"
}

cmd_doctor() {
	# --json → machine-parseable report; suppresses the human formatting so a
	# diff between two Macs' outputs is clean. See docs/cross-mac-setup.md for
	# the intended cross-mac verification workflow.
	local json=0
	if [[ "${1:-}" == "--json" ]]; then
		json=1
		shift
	fi

	if [[ $json -eq 1 ]]; then
		_cmd_doctor_json
		return
	fi

	cma_say "claude-multiacct doctor"
	cma_dim "  repo:   $CMA_REPO_ROOT"
	cma_dim "  config: $CMA_CONFIG_FILE"
	cma_dim "  logs:   $CMA_LOG_DIR"
	cma_dim "  backups: $CMA_BACKUP_DIR"
	printf '\n' >&2

	# Config presence.
	if [[ -f "$CMA_CONFIG_FILE" ]]; then
		cma_ok "config file present"
	else
		cma_warn "config file MISSING — run \`init\` first"
		return 1
	fi

	# Launchd agent state. All three agents get the same treatment.
	local label
	for label in com.user.claude-sessions-sync com.user.claude-clone-refresh com.user.claude-primary-patch-refresh com.user.claude-metadata-symlink; do
		if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
			cma_ok "launchd agent $label loaded"
			launchctl print "gui/$(id -u)/$label" 2>/dev/null | grep -E 'state|last exit code|watch paths' | sed 's/^/  /' >&2 || true
		else
			cma_warn "launchd agent $label NOT loaded"
		fi
	done

	# Per-instance discovery.
	printf '\n' >&2
	"$CMA_LIB/discover.sh"
}

# JSON doctor report — wraps discover.sh --json with launchd agent state +
# repo/config metadata. Designed for cross-mac diffing: two Macs' outputs
# should be structurally identical when the config is in sync.
#
# Uses printf-only JSON assembly (no jq — see metadata-symlinks.sh comment on
# why jq is deliberately avoided in this repo).
_cmd_doctor_json() {
	# JSON-escape a single value using the same rules as discover.sh's helper.
	local _escape='s/\\/\\\\/g;s/"/\\"/g;s/\t/\\t/g'

	local repo cfg logs backups
	repo="$(printf '%s' "$CMA_REPO_ROOT" | sed "$_escape")"
	cfg="$(printf '%s' "$CMA_CONFIG_FILE" | sed "$_escape")"
	logs="$(printf '%s' "$CMA_LOG_DIR" | sed "$_escape")"
	backups="$(printf '%s' "$CMA_BACKUP_DIR" | sed "$_escape")"

	# Launchd agent states.
	local ld_json="{"
	local first=1 label state
	for label in com.user.claude-sessions-sync com.user.claude-clone-refresh com.user.claude-primary-patch-refresh com.user.claude-metadata-symlink; do
		state="not-loaded"
		if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
			state="loaded"
		fi
		[[ $first -eq 1 ]] || ld_json+=","
		first=0
		ld_json+="\"$label\":\"$state\""
	done
	ld_json+="}"

	# Instances + primary — discover.sh --json now emits the Chunk Y shape
	# {"primary":{…}|null,"instances":[{…},…]}. We parse it out and stitch the
	# two halves into the doctor JSON so the top-level shape becomes
	# {"repo","config","logs","backups","launchd_agents","primary","instances"}.
	# The parse is deliberately python3 (stdlib on macOS) rather than a hand-
	# rolled regex — the discover.sh emission is trusted JSON, so json.loads +
	# json.dumps round-trips it losslessly + normalises whitespace.
	local instances_json primary_json="null" discover_json
	if [[ -f "$CMA_CONFIG_FILE" ]] || [[ -d "$CMA_SOURCE_CLAUDE_APP" ]]; then
		discover_json="$("$CMA_LIB/discover.sh" --json 2>/dev/null)"
	fi
	if [[ -n "${discover_json:-}" ]]; then
		# Split via python3 — discover.sh's output is a single JSON blob with
		# two keys, so this is a 2-line splitter.
		instances_json="$(printf '%s' "$discover_json" | python3 -c '
import json,sys
try:
	d = json.load(sys.stdin)
	print(json.dumps(d.get("instances", [])))
except Exception:
	print("[]")
')"
		primary_json="$(printf '%s' "$discover_json" | python3 -c '
import json,sys
try:
	d = json.load(sys.stdin)
	p = d.get("primary")
	print(json.dumps(p) if p is not None else "null")
except Exception:
	print("null")
')"
	fi
	[[ -n "$instances_json" ]] || instances_json="[]"
	[[ -n "$primary_json" ]] || primary_json="null"

	printf '{"repo":"%s","config":"%s","logs":"%s","backups":"%s","launchd_agents":%s,"primary":%s,"instances":%s}\n' \
		"$repo" "$cfg" "$logs" "$backups" "$ld_json" "$primary_json" "$instances_json"
}

cmd_qa() {
	local sub="${1:-}"
	case "$sub" in
	lint)
		# -P bin -P lib resolves the source directives in bin/claude-multiacct
		# (source=../lib/common.sh) and lib/*.sh (source=./common.sh) so SC1091
		# doesn't fire. bats files are shellcheckable too — they're bash + a bats
		# preamble shellcheck tolerates fine.
		cma_require shellcheck
		cma_say "shellcheck bin/ lib/ tests/"
		# $CMA_LIB/*.sh (not $CMA_LIB/*) — non-shell payloads under lib/ (e.g.
		# the session-propagation JS injected into app.asar at build-clone-app
		# time) are read by node, not sourced, and would trip SC1127 on their
		# JS-comment lines. Shellcheck is scoped to the .sh files it actually
		# understands; the JS is separately parse-checked by the bats runtime
		# harness test in tests/clone-app.bats.
		shellcheck -x -P "$CMA_BIN" -P "$CMA_LIB" "$CMA_BIN"/* "$CMA_LIB"/*.sh "$CMA_REPO_ROOT/tests"/*.bats 2>&1 || return $?
		cma_ok "shellcheck clean"

		# shfmt in check-only mode. Reads .editorconfig for its indent settings
		# (matches the shell block: indent_size=2, binary_next_line=true,
		# switch_case_indent=true, space_redirects=true). Same *.sh-only glob
		# rationale as shellcheck above.
		cma_require shfmt
		cma_say "shfmt bin/ lib/ tests/"
		shfmt -d "$CMA_BIN"/* "$CMA_LIB"/*.sh "$CMA_REPO_ROOT/tests"/*.bats 2>&1 || return $?
		cma_ok "shfmt clean"

		# gitleaks + yamllint are now REQUIRED (not optional). Both are pinned in
		# mise.toml — a missing tool means the caller hasn't run `mise install`.
		cma_require gitleaks
		cma_say "gitleaks"
		gitleaks detect --no-git --source "$CMA_REPO_ROOT" --config "$CMA_REPO_ROOT/.gitleaks.toml" --no-banner 2>&1 || return $?
		cma_ok "gitleaks clean"

		cma_require yamllint
		cma_say "yamllint config/ + .github/"
		# config/ holds our own scaffold yaml; .github/ holds Actions workflows,
		# dependabot.yml, ISSUE_TEMPLATE forms, all of which should stay
		# yamllint-clean so CI never breaks silently. Use a while-read loop
		# over find (not `for … $(find …)`) so paths containing whitespace or
		# weird characters don't split. Zero paths → yamllint runs with only
		# the config/ globs, which is fine.
		local yaml_targets=(
			"$CMA_REPO_ROOT/config"/*.yaml
		)
		if [[ -d "$CMA_REPO_ROOT/.github" ]]; then
			while IFS= read -r -d '' f; do
				yaml_targets+=("$f")
			done < <(find "$CMA_REPO_ROOT/.github" -type f \( -name '*.yml' -o -name '*.yaml' \) -print0)
		fi
		yamllint "${yaml_targets[@]}" 2>&1 || return $?
		cma_ok "yamllint clean"

		# markdownlint on README + docs. Skips the changelog + generated files.
		cma_require markdownlint-cli2
		cma_say "markdownlint README + docs"
		markdownlint-cli2 "$CMA_REPO_ROOT/README.md" "$CMA_REPO_ROOT/docs/**/*.md" 2>&1 || return $?
		cma_ok "markdownlint clean"
		;;
	format)
		# Rewrites shell files in-place per .editorconfig.
		cma_require shfmt
		cma_say "shfmt -w bin/ lib/ tests/"
		shfmt -w "$CMA_BIN"/* "$CMA_LIB"/*.sh "$CMA_REPO_ROOT/tests"/*.bats
		cma_ok "shfmt applied"
		;;
	test)
		cma_require bats
		cma_say "bats tests/"
		bats "$CMA_REPO_ROOT/tests"
		;;
	"test:coverage")
		# Bash line coverage via kcov, wrapping the bats runner.
		#
		# macOS-note: kcov uses PTRACE_ATTACH under the hood on darwin. On some
		# macOS versions it hangs when kcov spawns bats which spawns bash — the
		# per-descendant instrumentation deadlocks under System Integrity
		# Protection. When running on macOS locally, `qa test` (without coverage)
		# is the fallback. CI runs this same command on ubuntu-latest where
		# kcov works reliably.
		cma_require bats
		if ! command -v kcov >/dev/null 2>&1; then
			cma_die "qa test:coverage: kcov not on PATH. Install: brew install kcov (macOS) or apt install kcov (Linux)."
		fi
		local cov_dir="$CMA_REPO_ROOT/coverage"
		rm -rf "$cov_dir"
		mkdir -p "$cov_dir"
		cma_say "kcov + bats tests/ (threshold: 90% line coverage)"
		# Resolve bats to its real binary — kcov re-exec's under bash and can
		# miss mise's shim-directory search when running from another shell
		# depth. Passing the absolute path sidesteps the shim entirely.
		local bats_bin yq_bin
		bats_bin="$(command -v bats)"
		yq_bin="$(command -v yq)"
		# Preserve mise's shim directory on PATH inside kcov's subprocess
		# so bats-spawned bash finds yq + shellcheck when the tests fork
		# claude-multiacct + its lib/*.sh helpers.
		PATH="$(dirname "$bats_bin"):$(dirname "$yq_bin"):$PATH" \
			kcov \
			--include-path="$CMA_BIN,$CMA_LIB" \
			--exclude-path="$CMA_REPO_ROOT/node_modules,$CMA_REPO_ROOT/.mise,$CMA_REPO_ROOT/coverage,$CMA_REPO_ROOT/tests" \
			"$cov_dir" \
			"$bats_bin" "$CMA_REPO_ROOT/tests" || return $?
		# Extract percent-covered from kcov's summary JSON. kcov drops
		# coverage.json next to index.html in the top-level output dir.
		local pct
		if [[ -f "$cov_dir/coverage.json" ]]; then
			pct=$(yq -r '.percent_covered' "$cov_dir/coverage.json" 2>/dev/null || echo 0)
		else
			# Fall back to the merged report path used by newer kcov builds.
			local merged
			merged=$(find "$cov_dir" -type f -name 'coverage.json' -print -quit 2>/dev/null || true)
			pct=$(yq -r '.percent_covered' "$merged" 2>/dev/null || echo 0)
		fi
		# kcov may fail to produce coverage.json on macOS SIP-restricted runs.
		# In that case, treat as fatal so CI (Linux) is the source of truth.
		if [[ -z "$pct" || "$pct" == "0" ]]; then
			cma_die "qa test:coverage: could not read coverage.json from $cov_dir (kcov may be silently failing under SIP; CI runs this on ubuntu-latest which is reliable)."
		fi
		cma_say "coverage: ${pct}%"
		# bash lacks native float comparison — use awk. Fail loud if below 90.
		awk -v p="$pct" 'BEGIN { exit !(p+0 >= 90) }' ||
			cma_die "qa test:coverage: bash line coverage ${pct}% is below the 90% threshold"
		cma_ok "coverage ≥ 90% (${pct}%)"
		;;
	*) cma_die "qa: expected {lint|format|test|test:coverage}, got: ${sub:-<empty>}" ;;
	esac
}

# Auto-migrate: detect + heal bundle-id drift transparently at CLI startup so
# the user never needs a manual `refresh-clones` after this repo bumps the
# bundle-id namespace. Runs before every non-informational subcommand.
#
# Logic:
#   - No config file → nothing to migrate; return.
#   - No yq / plutil → skip (missing tooling; CLI itself will fail loudly
#     downstream if the user hasn't run `mise install` — no need to double-fire).
#   - For each instance in yaml: compare live Info.plist CFBundleIdentifier
#     to `cma_default_bundle_id <label>`. Any mismatch → drifted.
#   - Drifted set empty → return.
#   - Drifted set non-empty:
#       * Any mirror clone RUNNING → warn once and return (rebuild would
#         corrupt a live bundle). User's subcommand still runs after.
#       * All mirrors quit → re-run install-instance.sh for each drifted
#         label (idempotent path used by `repair` + `refresh-clones`), then
#         re-render launchd plists. Blocks the subcommand for ~30s per
#         drifted mirror the first time; no-op on every subsequent call.
#
# Escape hatch: CMA_SKIP_AUTO_MIGRATE=1 disables auto-migrate. Bats tests
# set it in setup() so hermetic runs don't accidentally trip auto-migrate
# when they explicitly mutate a bundle-id fixture (e.g. clone-app.bats).
_cma_maybe_migrate() {
	[[ "${CMA_SKIP_AUTO_MIGRATE:-0}" == "1" ]] && return 0
	[[ -f "$CMA_CONFIG_FILE" ]] || return 0
	command -v yq >/dev/null 2>&1 || return 0
	command -v plutil >/dev/null 2>&1 || return 0

	local drifted=()
	local label
	while IFS= read -r label; do
		[[ -z "$label" ]] && continue
		# cma_resolve_instance dies on invalid rows — swallow so one bad
		# entry doesn't take down the whole CLI.
		local row
		# shellcheck disable=SC2310  # deliberate: swallow per-instance errors to keep the CLI usable
		row="$(cma_resolve_instance "$label" 2>/dev/null)" || continue
		local _l _e _cdir _udata _cli app expected_bid
		IFS=$'\t' read -r _l _e _cdir _udata _cli app expected_bid <<<"$row"
		[[ -f "$app/Contents/Info.plist" ]] || continue
		local actual_bid
		actual_bid="$(plutil -extract CFBundleIdentifier raw "$app/Contents/Info.plist" 2>/dev/null || printf '')"
		[[ -z "$actual_bid" || "$actual_bid" == "$expected_bid" ]] && continue
		drifted+=("$label")
	done < <(yq -r '.instances[].label' "$CMA_CONFIG_FILE" 2>/dev/null || true)

	[[ ${#drifted[@]} -eq 0 ]] && return 0

	# Any mirror clone running → refuse to auto-rebuild (would corrupt a live
	# bundle) but let the user's subcommand proceed.
	if pgrep -f 'Claude Account .*\.app/Contents/MacOS' >/dev/null 2>&1; then
		cma_warn "bundle-id drift on: ${drifted[*]} — quit all Claude Account *.app processes and re-run any command to auto-migrate"
		return 0
	fi

	cma_say "auto-migrating bundle-id drift on: ${drifted[*]}"
	local l
	for l in "${drifted[@]}"; do
		"$CMA_LIB/install-instance.sh" "$l" >&2
	done
	"$CMA_LIB/install-launchd.sh" >&2
	cma_ok "auto-migrated: ${drifted[*]}"
}

main() {
	local cmd="${1:-}"
	shift || true
	# Skip auto-migrate on informational commands — no side effects wanted for
	# `--help`. Every real subcommand gets the drift check.
	case "$cmd" in
	"" | -h | --help | help) ;;
	*) _cma_maybe_migrate ;;
	esac
	case "$cmd" in
	"" | -h | --help | help) usage ;;
	install) cmd_install "$@" ;;
	uninstall) cmd_uninstall "$@" ;;
	init) cmd_init "$@" ;;
	add-instance) cmd_add_instance "$@" ;;
	remove-instance) cmd_remove_instance "$@" ;;
	list) cmd_list "$@" ;;
	repair) cmd_repair "$@" ;;
	refresh-clones) cmd_refresh_clones "$@" ;;
	primary-patch) cmd_primary_patch "$@" ;;
	primary-unpatch) cmd_primary_unpatch "$@" ;;
	sync-now) cmd_sync_now "$@" ;;
	sync-log) cmd_sync_log "$@" ;;
	exec) cmd_exec "$@" ;;
	doctor) cmd_doctor "$@" ;;
	qa) cmd_qa "$@" ;;
	*)
		usage
		cma_die "unknown subcommand: $cmd"
		;;
	esac
}

main "$@"
