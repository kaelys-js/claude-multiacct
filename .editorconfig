# https://editorconfig.org

root = true

# ============================================
# Global Defaults
# ============================================
[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 2
tab_width = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ============================================
# YAML (tabs are invalid per YAML spec)
# ============================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ============================================
# Markdown (trailing whitespace = line breaks)
# ============================================
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

# ============================================
# Lock Files & Generated (don't reformat)
# ============================================
[{package-lock.json,yarn.lock,pnpm-lock.yaml,bun.lockb,*.lock,*.tsbuildinfo,*.snap,*.min.*,**/CHANGELOG.md}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false
insert_final_newline = unset
