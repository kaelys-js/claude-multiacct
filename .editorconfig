# https://editorconfig.org

root = true

# ============================================
# Global Defaults
# ============================================
[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 2
tab_width = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ============================================
# YAML (tabs are invalid per YAML spec)
# ============================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ============================================
# Python (PEP 8: 4 spaces)
# ============================================
[*.py]
indent_style = space
indent_size = 4

# ============================================
# Shell (shfmt reads these keys directly)
#   2-space indent, indent switch-case bodies, break binary ops onto the next
#   line, and put a space after redirect operators.
# ============================================
[*.{sh,bash}]
indent_style = space
indent_size = 2
binary_next_line = true
switch_case_indent = true
space_redirects = true

# ============================================
# Go (community convention: tabs)
# ============================================
[*.go]
indent_style = tab
indent_size = 4

[{go.mod,go.sum}]
indent_style = tab
indent_size = 4

# ============================================
# Rust (rustfmt default: 4 spaces)
# ============================================
[*.rs]
indent_style = space
indent_size = 4

# ============================================
# Swift (SwiftFormat: 4 spaces)
# ============================================
[*.swift]
indent_style = space
indent_size = 4

# ============================================
# C / C++ / Objective-C (clang-format: 4 spaces)
# ============================================
[*.{c,h,cpp,hpp,cc,cxx,hxx,m,mm}]
indent_style = space
indent_size = 4

# ============================================
# Makefile (tabs required by Make)
# ============================================
[Makefile]
indent_style = tab
indent_size = 4

# ============================================
# Markdown (trailing whitespace = line breaks)
# ============================================
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

# ============================================
# Plain Text
# ============================================
[*.{txt,text}]
trim_trailing_whitespace = false

# ============================================
# Diff/Patch (preserve exactly)
# ============================================
[*.{diff,patch}]
trim_trailing_whitespace = false
insert_final_newline = false

# ============================================
# CSV/TSV (whitespace is data)
# ============================================
[*.{csv,tsv}]
trim_trailing_whitespace = false
insert_final_newline = true

# ============================================
# Windows Scripts (CRLF required)
# ============================================
[*.{bat,BAT,cmd,CMD,ps1,psm1,psd1}]
end_of_line = crlf

# ============================================
# iCalendar (RFC 5545 mandates CRLF line endings)
# ============================================
[*.ics]
end_of_line = crlf

# ============================================
# Kotlin (ktlint interop)
# ============================================
[*.{kt,kts}]
ktlint_standard_property-naming = disabled

# ============================================
# Apple/XML Property Lists (preserve tool output)
# ============================================
[*.{xml,plist,xcconfig,xcsettings,xcscheme,xcworkspacedata,pbxproj}]
indent_size = 2
trim_trailing_whitespace = false

# ============================================
# Lock Files & Generated (don't reformat)
# ============================================
[{package-lock.json,yarn.lock,pnpm-lock.yaml,bun.lockb,*.lock,*.tsbuildinfo,*.snap,*.min.*,**/CHANGELOG.md,**/Gemfile.lock,**/Package.resolved}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false
insert_final_newline = unset
