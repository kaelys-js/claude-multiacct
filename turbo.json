{
	"$schema": "./.schemas/turbo.json",
	"globalDependencies": ["mise.lock", "mise.toml"],
	"globalPassThroughEnv": ["NODE_ENV", "CI"],
	"ui": "tui",
	"dangerouslyDisablePackageManagerCheck": false,
	"tasks": {
		"clean": { "cache": false, "outputs": [] },
		"qa:hooks": { "inputs": ["lefthook.yml"], "outputs": [], "cache": false },
		"test": { "inputs": ["$TURBO_DEFAULT$"], "outputs": [] },
		"test:coverage:run": {
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": ["coverage/**"],
			"outputLogs": "new-only"
		},
		"lint:hygiene": { "inputs": ["$TURBO_DEFAULT$"], "outputs": [], "outputLogs": "new-only" },
		"lint:oxlint": {
			"inputs": [
				"**/*.cjs",
				"**/*.cts",
				"**/*.js",
				"**/*.jsx",
				"**/*.mjs",
				"**/*.mts",
				"**/*.ts",
				"**/*.tsx",
				".oxlintrc.json"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:typescript": {
			"inputs": ["**/*.cts", "**/*.mts", "**/*.ts", "**/*.tsx", "tsconfig.json"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"format:oxfmt": {
			"inputs": [
				"**/*.cjs",
				"**/*.css",
				"**/*.cts",
				"**/*.graphql",
				"**/*.js",
				"**/*.json",
				"**/*.jsonc",
				"**/*.jsx",
				"**/*.less",
				"**/*.md",
				"**/*.mdx",
				"**/*.mjs",
				"**/*.mts",
				"**/*.scss",
				"**/*.ts",
				"**/*.tsx",
				"**/*.yaml",
				"**/*.yml",
				".editorconfig",
				".oxfmtrc.json"
			],
			"outputs": [],
			"cache": false
		},
		"format:check:oxfmt": {
			"inputs": [
				"**/*.cjs",
				"**/*.css",
				"**/*.cts",
				"**/*.graphql",
				"**/*.js",
				"**/*.json",
				"**/*.jsonc",
				"**/*.jsx",
				"**/*.less",
				"**/*.md",
				"**/*.mdx",
				"**/*.mjs",
				"**/*.mts",
				"**/*.scss",
				"**/*.ts",
				"**/*.tsx",
				"**/*.yaml",
				"**/*.yml",
				".editorconfig",
				".oxfmtrc.json"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:yamllint": {
			"inputs": ["**/*.yaml", "**/*.yml", ".yamllint"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:taplo": {
			"inputs": ["**/*.toml", "taplo.toml"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"format:taplo": { "inputs": ["**/*.toml", "taplo.toml"], "outputs": [], "cache": false },
		"format:check:taplo": {
			"inputs": ["**/*.toml", "taplo.toml"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:markdownlint": {
			"inputs": ["**/*.md", "**/*.mdx", ".markdownlint-cli2.jsonc"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:check-jsonschema": {
			"inputs": ["**/*.schema.json"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:reuse": {
			"inputs": ["$TURBO_DEFAULT$", "REUSE.toml"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:gitleaks": {
			"inputs": ["$TURBO_DEFAULT$", ".gitleaks.toml"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:editorconfig": {
			"inputs": [
				"$TURBO_DEFAULT$",
				".editorconfig",
				".editorconfig-checker.json",
				"scripts/qa/editorconfig-check.ts"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:gitmeta": {
			"inputs": [
				"$TURBO_DEFAULT$",
				".gitattributes",
				".gitignore",
				".npmrc",
				"scripts/qa/gitmeta-check.ts"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint:schema": { "inputs": ["$TURBO_DEFAULT$"], "outputs": [], "outputLogs": "new-only" },
		"lint:syncpack": {
			"inputs": ["$TURBO_DEFAULT$", ".syncpackrc.json"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"format:syncpack": {
			"inputs": ["$TURBO_DEFAULT$", ".syncpackrc.json"],
			"outputs": [],
			"cache": false
		},
		"format:check:syncpack": {
			"inputs": ["$TURBO_DEFAULT$", ".syncpackrc.json"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"qa:lint:all": {
			"dependsOn": [
				"lint:hygiene",
				"lint:oxlint",
				"lint:typescript",
				"lint:yamllint",
				"lint:taplo",
				"lint:markdownlint",
				"lint:check-jsonschema",
				"lint:reuse",
				"lint:gitleaks",
				"lint:editorconfig",
				"lint:gitmeta",
				"lint:schema",
				"lint:syncpack"
			],
			"outputs": [],
			"cache": false
		},
		"qa:format:all": {
			"dependsOn": ["format:oxfmt", "format:taplo", "format:syncpack"],
			"outputs": [],
			"cache": false
		},
		"qa:format:check:all": {
			"dependsOn": ["format:check:oxfmt", "format:check:taplo", "format:check:syncpack"],
			"outputs": [],
			"cache": false
		}
	}
}
