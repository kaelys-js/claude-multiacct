// Authoritative markdownlint rule set (centralised in @foundation/config).
// This is a BARE markdownlint config (rules only), extended by the root
// `.markdownlint-cli2.jsonc` stub via `config.extends`. cli2-only options
// (globs, ignores) live in that stub, NOT here — they are not markdownlint keys.
// Markdown *formatting* is oxfmt's job, so layout rules oxfmt owns (line length,
// list/heading spacing) are disabled; what remains catches real documentation
// defects — broken structure, bad links, duplicate headings, raw HTML, missing
// code-fence languages.
{
	"$schema": "../../../.schemas/markdownlint.json",
	"default": true,

	// oxfmt owns wrapping and blank-line/whitespace layout.
	"MD013": false, // line-length
	"MD012": false, // multiple consecutive blank lines
	"MD009": false, // trailing spaces (oxfmt handles)

	// Structure & correctness (kept on):
	"MD003": { "style": "atx" }, // consistent heading style
	"MD004": { "style": "dash" }, // consistent unordered-list bullets
	"MD007": { "indent": 2 }, // nested-list indent
	"MD024": { "siblings_only": true }, // duplicate headings only under same parent
	"MD025": { "level": 1, "front_matter_title": "" }, // single H1; don't treat frontmatter `title:` as the H1 (records carry both)
	"MD029": { "style": "ordered" }, // ordered-list numbering
	// Allow the presentational HTML that centered READMEs conventionally use.
	"MD033": {
		"allowed_elements": [
			"br",
			"details",
			"summary",
			"kbd",
			"div",
			"p",
			"a",
			"img",
			"sub",
			"sup",
			"h1",
			"strong",
		],
	},
	"MD040": true, // fenced code blocks must declare a language
	"MD046": { "style": "fenced" }, // code-block style
	"MD048": { "style": "backtick" }, // code-fence style
	"MD049": { "style": "underscore" }, // emphasis style
	"MD050": { "style": "asterisk" }, // strong style

	// First line need not be a top-level heading (badges/frontmatter precede it).
	"MD041": false,
}
