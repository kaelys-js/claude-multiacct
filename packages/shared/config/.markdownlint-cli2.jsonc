// Authoritative markdownlint-cli2 config (centralised in @foundation/config),
// reached by `markdownlint-cli2 --config packages/shared/config/.markdownlint-cli2.jsonc`
// (see packages/shared/utils/qa/src/registry.ts). The QA dispatch also passes `--no-globs` so the
// `globs` below stay inert and only the dispatch's explicit file list is linted;
// `ignores` still filter. `config.extends` pulls in the sibling rule set and
// resolves relative to THIS file's directory (packages/shared/config/).
{
	"$schema": "../../../.schemas/markdownlint-cli2.json",
	"config": {
		"extends": "markdownlint.jsonc",
	},
	"globs": ["**/*.md", "**/*.mdx"],
	// The record templates carry deliberate fill-in placeholders (<title>, <Option A>,
	// <pro>…) that markdownlint misreads as inline HTML (MD033); real records have no
	// placeholders, so records/ stays linted. oxfmt still formats the templates. The
	// path is the explicit package location (a bare `templates` ignore matches only a
	// root-level dir, not the nested @foundation/registry one).
	"ignores": [
		"node_modules",
		".mise",
		"dist",
		"build",
		"coverage",
		"CHANGELOG.md",
		"packages/products/registry/templates",
	],
}
