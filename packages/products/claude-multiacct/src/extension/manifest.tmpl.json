{
	"manifest_version": 3,
	"name": "claude-multiacct code-tab picker",
	"description": "Adds a per-session account picker + usage pill to the Claude Code tab.",
	"version": "__VERSION__",
	"permissions": ["storage"],
	"content_scripts": [
		{
			"matches": ["https://claude.ai/*"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["bridge.json"],
			"matches": ["https://claude.ai/*"]
		}
	]
}
