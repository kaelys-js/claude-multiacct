// markdownlint-cli2 config — layout rules off, semantic rules on.
// Layout is inconsistent across pre-existing docs; enforcing every default
// rule here means either a large reformat or per-line disables. We keep
// syntax-affecting rules (heading levels, list markers) and drop the noisy
// layout ones. Add rules back as docs stabilise.
{
	"$schema": "./.schemas/markdownlint-cli2.json",
	"config": {
		"MD013": false, // line-length — narrative prose can exceed 80
		"MD024": false, // no-duplicate-heading — allow repeated section names
		"MD031": false, // blanks-around-fences — pre-existing docs skip blank lines
		"MD032": false, // blanks-around-lists — pre-existing docs skip blank lines
		"MD033": false, // no-inline-html — <dl> + <details> are used intentionally
		"MD040": false, // fenced-code-language — pre-existing snippets omit language
		"MD041": false, // first-line-h1 — some docs start with front-matter
		"MD060": false, // table-column-style — compact tables in README are readable
		"default": true,
	},
	"globs": ["README.md", "docs/**/*.md"],
	"ignores": ["node_modules/**", ".mise/**", "coverage/**"],
}
